# Токен пользовательского бота (получить у @BotFather)
USER_BOT_TOKEN=123456789:AAExampleUserBotTokenHere

# Токен админ-бота (получить у @BotFather — отдельный бот)
ADMIN_BOT_TOKEN=987654321:AAExampleAdminBotTokenHere

# Telegram ID администраторов через запятую (узнать у @userinfobot)
ADMIN_IDS=123456789,987654321

# Числовой ID канала для проверки подписки (вида -1001234567890).
# USER_BOT должен быть администратором этого канала.
# Узнать ID: переслать любое сообщение из канала боту @userinfobot или @getidsbot
CHANNEL_ID=-1001234567890

# Ссылка-приглашение на канал для кнопки «Подписаться».
CHANNEL_URL=https://t.me/+NT6WIW-KEcwyNTU6
